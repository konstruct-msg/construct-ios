# Rust (if used in future)
target/
**/*.rs.bk
*.pdb
Cargo.lock
.cargo/

# ── Compiled Rust static libraries ───────────────────────────────────────────
# These are built locally by running build_crypto_lib.sh before development.
# Never commit — they are large, architecture-specific, and must always
# match the current construct-core source.
libconstruct_core.a
libconstruct_core_mac.a
libconstruct_core_sim.a
ConstructCore.xcframework/**/*.a

# Build outputs
dist/
build/
.next/
out/
.vercel/
.turbo/
logs/

# Xcode per-user state
*.xcuserstate


# Static library symbol files (macOS)
__.SYMDEF
*.SYMDEF

# Environment
.env
.env.local
.env.*.local

# IDEs
.vscode/
.zed/
.claude/
.idea/
*.swp
*.swo
*~
.DS_Store

# Testing
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
*.tmp

# OS
.DS_Store
Thumbs.db

# Rust object files (accidentally extracted from .a archives)
*.o
*.rcgu.o
__.SYMDEF

# Python
test_*.py
!tests/**/*.py
*.pyc
__pycache__/
venv/
*.egg-info/
.mypy_cache/

ConstructEngine.xcframework/**/*.a
ConstructTransport.xcframework/**/*.a
screenshots/

# ── GeoIP databases ───────────────────────────────────────────────────────────
# Downloaded automatically by scripts/fetch_geoip.sh (or the Xcode Build Phase).
# Never committed — updated monthly from P3TERX/GeoLite.mmdb.
GeoLite2-Country.mmdb
GeoLite2-ASN.mmdb

# ── Swift / Xcode / SwiftPM build artifacts ───────────────────────────────────
# SwiftPM build cache (e.g. ConstructUI/.build/, including index-build/*.mdb) —
# large, machine-specific, and regenerated on every build. Never commit.
.build/
.swiftpm/
DerivedData/
*.xcuserstate
xcuserdata/
